  "subtitleSystem": {
    "safeBox": {
      "x": 80,
      "y": 1320,
      "w": 920,
      "h": 280
    },
    "maxLines": 2,
    "emergencyMaxLines": 3,
    "alignment": "center",
    "highlighting": true,
    "rules": [
      "never overlap header",
      "never overlap progress dots",
      "never overlap pros/cons bullets",
      "lift subtitles upward when a section gets dense"
    ]
